APP_ENV=development
APP_NAME=Et Demo API
APP_VERSION=1.0.0
# SQLite 상대 경로(./et_demo.db 등)는 셸 cwd가 아니라 프로젝트 루트(ai_coding_web) 기준으로 해석됩니다.
DATABASE_URL=sqlite:///./et_demo.db
# Supabase: Dashboard → Settings → API → JWT 서명 비밀값 (anon 키와 다릅니다)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Dashboard → API → anon public 키 (백엔드가 Supabase Auth REST 프록시에 사용, 프론트 config.js와 동일 값)
SUPABASE_ANON_KEY=your-anon-or-publishable-key
SUPABASE_JWT_SECRET=your-jwt-signing-secret
# 선택: 토큰 iss 검증용. 비우면 SUPABASE_URL 기준으로 https://.../auth/v1 를 사용합니다.
# SUPABASE_JWT_ISSUER=
# 회원탈퇴( Auth 사용자 삭제 ) API용 — Dashboard → API → service_role (절대 프론트/깃에 노출 금지)
# SUPABASE_SERVICE_ROLE_KEY=
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500
AUTH_COOKIE_NAME=et_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_SESSION_TTL_HOURS=168
AUTH_SEED_DEMO_USER=true
AUTH_DEMO_USER_EMAIL=demo@et.ai
AUTH_DEMO_USER_PASSWORD=etl1234
ETL_SHARED_SECRET=change-me
