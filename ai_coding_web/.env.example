APP_ENV=development
APP_NAME=Et Demo API
APP_VERSION=1.0.0
# SQLite 상대 경로(./et_demo.db 등)는 셸 cwd가 아니라 프로젝트 루트(ai_coding_web) 기준으로 해석됩니다.
DATABASE_URL=sqlite:///./et_demo.db
# Supabase: Dashboard → Settings → API → JWT 서명 비밀값 (anon 키와 다릅니다)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Dashboard → API → anon public 키 (백엔드가 Supabase Auth REST 프록시에 사용, 프론트 config.js와 동일 값)
SUPABASE_ANON_KEY=your-anon-or-publishable-key
SUPABASE_JWT_SECRET=your-jwt-signing-secret
# 선택: 토큰 iss 검증용. 비우면 SUPABASE_URL 기준으로 https://.../auth/v1 를 사용합니다.
# SUPABASE_JWT_ISSUER=
# 회원탈퇴( Auth 사용자 삭제 ) API용 — Dashboard → API → service_role (절대 프론트/깃에 노출 금지)
# SUPABASE_SERVICE_ROLE_KEY=
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500
AUTH_COOKIE_NAME=et_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_SESSION_TTL_HOURS=168
AUTH_SEED_DEMO_USER=true
AUTH_DEMO_USER_EMAIL=demo@et.ai
AUTH_DEMO_USER_PASSWORD=etl1234
ETL_SHARED_SECRET=change-me
# 워드클라우드·분석: local=SQLite / supabase=Supabase REST
CONTENT_SOURCE=local
# 정규화 DB(FK 코드 컬럼)일 때만: normalized
# SUPABASE_WORDCLOUD_SCHEMA=normalized

# 공공데이터포털 — 한국농수산식품유통공사 priceSequel/info (https://www.data.go.kr → 활용신청 후 인증키)
# DATA_GO_KR_SERVICE_KEY=
# AT_PRICE_API_PATH=/B552845/priceSequel/info
# 필수 조사일 YYYYMMDD (비우면 KST 전일 자동). 또는 AT_PRICE_API_QUERY_JSON 에 "cond[exmn_ymd::EQ]" 포함
# AT_PRICE_EXMN_YMD=20250328
# 올해 기준 N년 전까지 월별 샘플로 이력 수집(0=단일 조사일만, 전 페이지). 기본 3
# AT_PRICE_HISTORY_YEARS=3
# AT_PRICE_REQUEST_SLEEP_SEC=0.25
# 선택 필터: # AT_PRICE_API_QUERY_JSON={"cond[item_cd::EQ]":"14101"}
# AT_PRICE_API_BASE=https://apis.data.go.kr
# AT_PRICE_RESULT_TYPE=json

# ── 의료·교통·관광·환경 공공 API (data.go.kr, 경로·쿼리는 명세에 맞게) ──
# PD_API_BASE=https://apis.data.go.kr
# PD_HEALTH_API_PATH=
# PD_HEALTH_API_QUERY_JSON={}
# PD_HEALTH_NUM_OF_ROWS=500
# PD_TRAFFIC_API_PATH=
# PD_TRAFFIC_API_QUERY_JSON={}
# PD_TOUR_API_PATH=
# PD_TOUR_API_QUERY_JSON={}
# PD_ENV_API_PATH=
# PD_ENV_API_QUERY_JSON={}

# 워드클라우드: 카테고리 연관도(ML, sklearn) — 1=켜면 가중치·저관련어 필터
# WORDCLOUD_USE_ML_REL=0
# WORDCLOUD_ML_MIN_SCORE=0.25
