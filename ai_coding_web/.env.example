APP_ENV=development
APP_NAME=Et Demo API
APP_VERSION=1.0.0

# ── 데이터베이스 ─────────────────────────────────────────────────────────
# 로컬 개발: SQLite (상대 경로는 프로젝트 루트 기준)
DATABASE_URL=sqlite:///./et_demo.db
# Docker / 프로덕션: PostgreSQL
# DATABASE_URL=postgresql+psycopg://etuser:password@localhost:5432/etapp

# ── Docker Compose 전용 (docker-compose.yml 참조) ────────────────────────
# POSTGRES_DB=etapp
# POSTGRES_USER=etuser
# POSTGRES_PASSWORD=change-me-strong-password
# HTTP_PORT=80

# ── CORS ──────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500

# ── 인증 ──────────────────────────────────────────────────────────────────
# 세션은 HttpOnly 쿠키(et_session). Supabase JWT는 사용하지 않음.
# Docker에서 nginx로 HTTP만 쓸 때: AUTH_COOKIE_SECURE=false 필수(아니면 쿠키가 저장되지 않음).
# 외부에 HTTPS만 노출할 때: AUTH_COOKIE_SECURE=true + SameSite는 lax 또는 none(크로스 도메인 시).
AUTH_COOKIE_NAME=et_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_SESSION_TTL_HOURS=168
AUTH_SEED_DEMO_USER=true
AUTH_DEMO_USER_EMAIL=demo@et.ai
AUTH_DEMO_USER_PASSWORD=etl1234

# ── ETL ───────────────────────────────────────────────────────────────────
ETL_SHARED_SECRET=change-me

# ── 공공데이터포털 API ─────────────────────────────────────────────────────
# 한국농수산식품유통공사 priceSequel/info (https://www.data.go.kr → 활용신청 후 인증키)
# DATA_GO_KR_SERVICE_KEY=
# AT_PRICE_API_PATH=/B552845/priceSequel/info
# 필수 조사일 YYYYMMDD (비우면 KST 전일 자동)
# AT_PRICE_EXMN_YMD=
# 올해 기준 N년 전까지 이력 수집 (0=단일 조사일만). 기본 3
# AT_PRICE_HISTORY_YEARS=3
# AT_PRICE_REQUEST_SLEEP_SEC=0.25
# AT_PRICE_API_BASE=https://apis.data.go.kr

# ── 의료·교통·관광·환경 공공 API ─────────────────────────────────────────
# PD_API_BASE=https://apis.data.go.kr
# PD_HEALTH_API_PATH=
# PD_HEALTH_API_QUERY_JSON={}
# PD_TRAFFIC_API_PATH=
# PD_TRAFFIC_API_QUERY_JSON={}
# PD_TOUR_API_PATH=
# PD_TOUR_API_QUERY_JSON={}
# PD_ENV_API_PATH=
# PD_ENV_API_QUERY_JSON={}

# ── 워드클라우드 ML ───────────────────────────────────────────────────────
# WORDCLOUD_USE_ML_REL=0
# WORDCLOUD_ML_MIN_SCORE=0.25
